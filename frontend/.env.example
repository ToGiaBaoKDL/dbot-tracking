# =============================================================================
# DBOT Frontend — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in all required values (marked with *)
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
# (*) Backend API URL. Must start with NEXT_PUBLIC_ to be exposed to browser.
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# NextAuth.js
# -----------------------------------------------------------------------------
# (*) Your frontend base URL
NEXTAUTH_URL=http://localhost:3000

# (*) NextAuth secret for JWT encryption. Generate with:
#    openssl rand -base64 32
NEXTAUTH_SECRET=
