# =============================================================================
# Root .env — Backend, Postgres, Airflow, Docker
# =============================================================================
# Copy this file to .env and fill in required values.
# Frontend has its own .env at frontend/.env
# =============================================================================

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stock_signals
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/stock_signals

# Backend
# (*) SECRET_KEY: used for JWT signing + Fernet encryption.
#    Must be >= 32 bytes. Generate with:
#    python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Comma-separated list of frontend origins for CORS
CORS_ORIGINS=http://localhost:3000

# Disable public registration (default: false)
REGISTRATION_DISABLED=false

# Docker
# Host Docker group ID for Airflow to access Docker socket.
# Find with: getent group docker | cut -d: -f3
DOCKER_GID=999

# Docker image for ETL tasks (DockerOperator).
# Dev: built by `make rebuild-backend` (compose project name + latest)
# Prod: toilachuoituyet/dbot-backend:latest (pulled from Docker Hub)
DBOT_BACKEND_IMAGE=dbot-tracking-backend:latest

# Docker network name used by Airflow DAGs (DockerOperator).
# docker-compose.dev.yml default: dbot-tracking_default
# docker-compose.prod.yml: dbot-network
DBOT_DOCKER_NETWORK=dbot-tracking_default

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__DEFAULT_TIMEZONE=Asia/Ho_Chi_Minh
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:postgres@postgres:5432/airflow
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=false
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Email notification (Gmail SMTP)
# SMTP_PASSWORD: Gmail App Password (16 chars, NOT your regular password)
#   - Format: "xxxx xxxx xxxx xxxx" (4 groups, MUST wrap in quotes!)
#   - Without quotes only the first word is read
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Production only (Oracle Cloud)
CF_TUNNEL_TOKEN=
OOS_ACCESS_KEY=
OOS_SECRET_KEY=
OOS_NAMESPACE=
OOS_REGION=
OOS_BUCKET=dbot-backups
