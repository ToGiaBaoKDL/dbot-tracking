# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stock_signals
# Note: For production, change POSTGRES_PASSWORD and DATABASE_URL password
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/stock_signals

# Backend
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Airflow
AIRFLOW_UID=1000
AIRFLOW_GID=0
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:postgres@postgres:5432/airflow
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=false
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=false
AIRFLOW__CORE__DEFAULT_TIMEZONE=Asia/Ho_Chi_Minh
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# NextAuth (Frontend)
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXT_PUBLIC_API_URL=http://localhost:8000
