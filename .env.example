# =============================================================================
# DBOT Stock Signals Tracker — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in all required values (marked with *)
# =============================================================================

# -----------------------------------------------------------------------------
# Database (shared by Backend, Airflow, Postgres)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stock_signals
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/stock_signals

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
# (*) SECRET_KEY: used for JWT signing + Fernet encryption.
#    Must be at least 32 bytes. Generate with:
#    python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# JWT algorithm (default: HS256). Only change if you know what you're doing.
# ALGORITHM=HS256

# JWT expiry in minutes (default: 240 = 4 hours)
# ACCESS_TOKEN_EXPIRE_MINUTES=240

# Backend bind host/port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Comma-separated list of frontend origins for CORS
CORS_ORIGINS=http://localhost:3000

# Enable debug mode (default: false). Never set to true in production.
# DEBUG=false

# Disable public registration (default: false). Set to true for invite-only.
# REGISTRATION_DISABLED=false

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Host Docker group ID for Airflow to access Docker socket.
# Find with: getent group docker | cut -d: -f3
DOCKER_GID=999

# Docker network name used by Airflow DAGs (DockerOperator).
# docker-compose.yml default: dbot-tracking_default
# docker-compose.swarm.yml: dbot-network
DBOT_DOCKER_NETWORK=dbot-tracking_default

# Docker image for ETL tasks (DockerOperator).
# Default: toilachuoituyet/dbot-backend:latest (Docker Hub)
# Local dev: dbot-tracking-backend:latest (built by `make rebuild-backend`)
DBOT_BACKEND_IMAGE=dbot-tracking-backend:latest

# -----------------------------------------------------------------------------
# Airflow
# -----------------------------------------------------------------------------
AIRFLOW_UID=1000
AIRFLOW_GID=0
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__DEFAULT_TIMEZONE=Asia/Ho_Chi_Minh
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:postgres@postgres:5432/airflow
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=false
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# NextAuth (used by Swarm deploy script to create Docker secrets)
# -----------------------------------------------------------------------------
# (*) Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
